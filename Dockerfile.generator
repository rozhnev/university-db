FROM python:3.12-slim

WORKDIR /app

# Install dependencies first (cached layer unless requirements change)
RUN pip install --no-cache-dir \
    faker==24.* \
    mysql-connector-python==8.* \
    numpy==1.*

COPY generate_data.py .

# Entrypoint reads DB connection from environment variables set in docker-compose
ENTRYPOINT ["python", "generate_data.py"]
